{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marouba Companion Mac",
  "version": "0.7.0",
  "identifier": "com.nxeratech.marouba.companion.mac",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Marouba Companion Mac",
        "width": 320,
        "height": 220,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
